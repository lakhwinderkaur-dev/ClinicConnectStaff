@model IEnumerable<ClinicConnectStaff.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="cc-page">
    <div class="cc-page-header">
        <h1>Appointments</h1>
        <a asp-action="Create" class="btn-cc-primary">+ New Appointment</a>
    </div>

    <div class="cc-card">
        <table class="cc-table">
            <thead>
                <tr>
                    <th>Patient</th>
                    <th>Doctor</th>
                    <th>Specialty</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Status</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model) {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Patient.FullName)</td>
                    <td>@Html.DisplayFor(modelItem => item.DoctorName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Specialty)</td>
                    <td>@Html.DisplayFor(modelItem => item.AppointmentDate)</td>
                    <td>@Html.DisplayFor(modelItem => item.AppointmentTime)</td>
                    <td>
                       @{ var statusClass = item.Status.Trim().ToLower() == "upcoming" ? "cc-badge-upcoming" : "cc-badge-completed"; }
                        <span class="cc-badge @statusClass">@item.Status</span>
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Notes)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> ·
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a> ·
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
</div>