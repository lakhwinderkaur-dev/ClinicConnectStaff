@model ClinicConnectStaff.Models.Appointment

@{
    ViewData["Title"] = "Delete Appointment";
}

<div class="cc-page">
    <div class="cc-page-header">
        <h1>Delete Appointment</h1>
    </div>

    <div class="cc-card" style="padding:24px;">
        <p>Are you sure you want to delete this appointment?</p>
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Patient.Email)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DoctorName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.DoctorName)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AppointmentDate)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AppointmentDate)</dd>
        </dl>
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-cc-primary" style="background:#E25A45;">Delete</button>
            <a asp-action="Index" class="btn-cc-outline" style="margin-left:8px;">Cancel</a>
        </form>
    </div>
</div>