@model ClinicConnectStaff.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="cc-page">
    <div class="cc-page-header">
        <h1>Appointment Details</h1>
    </div>

    <div class="cc-card" style="padding:24px;">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Patient)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Patient.FullName)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DoctorName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.DoctorName)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Specialty)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Specialty)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AppointmentDate)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AppointmentDate)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.AppointmentTime)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.AppointmentTime)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
            <dd class="col-sm-9">
               @{ var statusClass = Model!.Status.Trim().ToLower() == "upcoming" ? "cc-badge-upcoming" : "cc-badge-completed"; }
                <span class="cc-badge @statusClass">@Model.Status</span>
            </dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Notes)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Notes)</dd>
        </dl>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-cc-primary">Edit</a>
        <a asp-action="Index" class="btn-cc-outline" style="margin-left:8px;">Back to List</a>
    </div>
</div>