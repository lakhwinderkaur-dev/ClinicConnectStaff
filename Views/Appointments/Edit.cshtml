@model ClinicConnectStaff.Models.Appointment

@{
    ViewData["Title"] = "Edit Appointment";
}

<div class="cc-page">
    <div class="cc-page-header">
        <h1>Edit Appointment</h1>
    </div>

    <div class="cc-card" style="padding:24px; max-width:480px;">
        <form asp-action="Edit" class="cc-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="PatientId" class="form-label"></label>
                <select asp-for="PatientId" class="form-control" asp-items="ViewBag.PatientId"></select>
                <span asp-validation-for="PatientId" class="text-danger"></span>
            </div>
           <div class="mb-3">
    <label asp-for="DoctorName" class="form-label"></label>
    <select asp-for="DoctorName" class="form-control" asp-items="ViewBag.DoctorOptions"></select>
</div>
<div class="mb-3">
    <label asp-for="Specialty" class="form-label"></label>
    <input asp-for="Specialty" class="form-control" placeholder="Auto-fills based on doctor, or type your own" />
    <span asp-validation-for="Specialty" class="text-danger"></span>
</div>
<div class="mb-3">
            <div class="mb-3">
                <label asp-for="AppointmentDate" class="form-label"></label>
                <input asp-for="AppointmentDate" class="form-control" />
                <span asp-validation-for="AppointmentDate" class="text-danger"></span>
            </div>
           <div class="mb-3">
    <label asp-for="AppointmentTime" class="form-label"></label>
    <select asp-for="AppointmentTime" class="form-control" asp-items="ViewBag.TimeOptions"></select>
</div>
<div class="mb-3">
    <label asp-for="Status" class="form-label"></label>
    <select asp-for="Status" class="form-control" asp-items="ViewBag.StatusOptions"></select>
</div>
            <div class="mb-3">
                <label asp-for="Notes" class="form-label"></label>
                <input asp-for="Notes" class="form-control" />
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>
            <button type="submit" class="btn-cc-primary">Save Changes</button>
            <a asp-action="Index" class="btn-cc-outline" style="margin-left:8px;">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}