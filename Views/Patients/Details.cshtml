@model ClinicConnectStaff.Models.Patient

@{
    ViewData["Title"] = "Patient Details";
}

<div class="cc-page">
    <div class="cc-page-header">
        <h1>Patient Details</h1>
    </div>

    <div class="cc-card" style="padding:24px;">
        <dl class="row">
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FullName)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.FullName)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Email)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Email)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Phone)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Phone)</dd>
            <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DateOfBirth)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.DateOfBirth)</dd>
        </dl>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn-cc-primary">Edit</a>
        <a asp-action="Index" class="btn-cc-outline" style="margin-left:8px;">Back to List</a>
    </div>
</div>